<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<metalib tagsetversion="1" name="tqqapi" version="14">
	<macro name="TQQ_KEY_LEN" value="16" />
	<macro name="TQQ_MAX_NAME_LEN" value="32" />
	<macro name="TQQ_MAX_IDENT_LEN" value="16" />
	<macro name="TQQ_MAX_SIGN_LEN" value="128" />
	<macro name="TQQ_MAX_SIGN2_LEN" value="64" />
	<macro name="TQQ_IDENT_LEN" value="16" />
	<macro name="TQQ_MAX_USERIDENT_LEN" value="64" />
	<macro name="TQQ_SVCBITMAP_LEN" value="12" />
	<macro name="TQQ_SVCBITMAP_EXT_LEN" value="8" />
	<macro name="TQQ_UNIFIED_MAX_SIGN_LEN" value="256" />
	<macro name="TQQ_UNIFIED_MAX_ENCSIGN_LEN" value="128" />
	<macro name="TQQ_UNIFIED_MAX_ENCSIGN2_LEN" value="32" />
	<macro name="TQQ_UNIFIED_CUSTOMINFO_LEN" value="32" />
	<macro name="TPDU_MAX_ENCRYPTSKEY_LEN" value="128" />
	<macro name="TPDU_MAX_ENCRYPTIDENT_LEN" value="64" />
	<macro name="TPDU_MAX_ENCRYPTSYN_LEN" value="128" />
	<macro name="TPDU_MAX_ENCRYPTSYNACK_LEN" value="128" />
	<macro name="TPDU_MAX_MIBAOBUFFER_LEN" value="4096" />
	<macro name="TPDU_MAGIC" value="85" desc="Protocol magic number" />
	<macro name="TPDU_VERSION" value="14" desc="Client protocol version" />
	<macrosgroup name="TCONN_SEC_ENC">
		<macro name="TCONN_SEC_NONE" value="0" />
		<macro name="TCONN_SEC_TEA" value="1" />
		<macro name="TCONN_SEC_QQ" value="2" />
		<macro name="TCONN_SEC_AES" value="3" />
		<macro name="TCONN_SEC_AES2" value="4" desc="Different from TCONN_SEC_AES, uses modified data padding algorithm" />
	</macrosgroup>
	<macrosgroup name="TCONN_SEC_AUTH">
		<macro name="TCONN_SEC_AUTH_NONE" value="0" />
		<macro name="TCONN_SEC_AUTH_QQV1" value="1" />
		<macro name="TCONN_SEC_AUTH_QQV2" value="2" />
		<macro name="TCONN_SEC_AUTH_QQUNIFIED" value="3" />
	</macrosgroup>
	<macrosgroup name="TPDU_CMD">
		<macro name="TPDU_CMD_NONE" value="0" desc="Communication packet" />
		<macro name="TPDU_CMD_CHGSKEY" value="1" desc="Key exchange (downstream)" />
		<macro name="TPDU_CMD_QUEINFO" value="2" desc="Queue information (downstream)" />
		<macro name="TPDU_CMD_AUTH" value="3" desc="Signature request (upstream)" />
		<macro name="TPDU_CMD_IDENT" value="4" desc="Connection established (downstream)" />
		<macro name="TPDU_CMD_PLAIN" value="5" desc="Unencrypted communication packet (downstream)" />
		<macro name="TPDU_CMD_RELAY" value="6" desc="Reconnection request (upstream)" />
		<macro name="TPDU_CMD_STOP" value="7" desc="Server disconnect with error code" />
		<macro name="TPDU_CMD_SYN" value="8" desc="Connection handshake (downstream)" />
		<macro name="TPDU_CMD_SYNACK" value="9" desc="Three-way handshake request (upstream)" />
		<macro name="TPDU_CMD_MBA_QUERYRSP" value="10" desc="Security question query response (downstream)" />
		<macro name="TPDU_CMD_MBA_VERIFYREQ" value="11" desc="Security question verification request (upstream)" />
		<macro name="TPDU_CMD_MBA_VERIFYRSP" value="12" desc="Security question verification result (downstream)" />
		<macro name="TPDU_CMD_CLOSE" value="13" desc="Client close connection notification (upstream)" />
		<macro name="TPDU_CMD_CLIENT_ADDR" value="210" desc="Client real address message from TGC (upstream)" />
	</macrosgroup>
	<macrosgroup name="TPDU_RELAY_TYPE" desc="Reconnection type">
		<macro name="TPDU_JUMP_SERVER_RELAY" value="1" desc="Cross-server jump" />
		<macro name="TPDU_NETWORK_FAILURE_RELAY" value="2" desc="Network disconnect reconnection" />
		<macro name="TPDU_CLIENT_CRASH_RELAY" value="3" desc="Reserved value" />
	</macrosgroup>
	<macrosgroup name="TPDU_STOP_REASON" desc="Error codes for tconnd internal logic disconnection">
		<macro name="TPDU_REASON_NONE" value="0" desc="Success" />
		<macro name="TPDU_REASON_IDLE_CLOSE" value="1" desc="Connection idle timeout close" />
		<macro name="TPDU_REASON_BAD_PKGLEN" value="4" desc="Invalid request packet length" />
		<macro name="TPDU_REASON_EXCEED_LIMIT" value="5" desc="Client send rate exceeded limit" />
		<macro name="TPDU_REASON_SELF_CLOSE" value="7" desc="Logic server initiated close" />
		<macro name="TPDU_REASON_AUTH_FAIL" value="8" desc="Client connection signature verification failed" />
		<macro name="TPDU_REASON_REASON_SYNACK_FAIL" value="9" desc="Client three-way handshake verification failed" />
		<macro name="TPDU_REASON_SEQUENCE_INVALID" value="11" desc="Invalid upstream packet sequence number" />
		<macro name="TPDU_REASON_RELAY_FAIL" value="14" desc="Client reconnection failed" />
		<macro name="TPDU_REASON_MBA_FAIL" value="15" desc="Security question processing failed" />
		<macro name="TPDU_REASON_MBA_TIMEOUT" value="16" desc="Security question response timeout" />
		<macro name="TPDU_REASON_REACH_LIMIT" value="100" desc="Connection limit reached" />
	</macrosgroup>
	<struct name="TQQGameSig" version="10" desc="0x82 signature first segment">
		<entry name="GameKey" type="char" count="TQQ_KEY_LEN"/>
		<entry name="SvcBitmap" type="char" count="TQQ_SVCBITMAP_LEN"/>
		<entry name="SvcBitmapExt" type="char" count="TQQ_SVCBITMAP_EXT_LEN"/>
		<entry name="ValidateBitmap" type="uint"/>
		<entry name="Uin" type="uint"/>
		<entry name="Time" type="uint"/>
		<entry name="UinFlag" type="uint"/>
		<entry name="ClientIP" type="uint" version="12" desc="Client IP address"/>
	</struct>

	<struct name="TQQSigForS2" version="10" desc="0x82 signature second segment, generally not used">
		<entry name="Type" type="tinyint"/>
		<entry name="ValidateBitmap" type="uint"/>
		<entry name="Uin" type="uint"/>
		<entry name="Time" type="uint"/>
		<entry name="CltIP" type="uint"/>
	</struct>

	<struct name="TQQUserIdent" version="10" desc="Reconnection verification field">
		<entry name="Uin" type="uint"/>
		<entry name="Pos" type="int"/>
		<entry name="Ident" type="char" count="TQQ_IDENT_LEN"/>
	</struct>

	<struct name="TQQAuthInfo" version="10" desc="0x82 signature protocol">
		<entry name="Uin" type="uint"/>
		<entry name="SignLen" type="tinyuint"/>
		<entry name="SignData" type="tinyuint" count="TQQ_MAX_SIGN_LEN" refer="SignLen"/>
		<entry name="Sign2Len" type="tinyuint"/>
		<entry name="Sign2Data" type="tinyuint" count="TQQ_MAX_SIGN2_LEN" desc="Generally not used" refer="Sign2Len"/>
	</struct>

	<struct name="TQQUnifiedSig" version="10" desc="0xDE signature protocol format">
		<entry name="Version" type="short"/>
		<entry name="Time" type="uint"/>
		<entry name="EncryptSignLen" type="short"/>
		<entry name="EncryptSignData" type="tinyuint" count="TQQ_UNIFIED_MAX_ENCSIGN_LEN" refer="EncryptSignLen"/>
	</struct>

	<struct name="TQQUnifiedEncrySig" version="10" desc="0xDE signature protocol encrypted portion">
		<entry name="Random" type="int"/>
		<entry name="Version" type="short" default="1"/>
		<entry name="uin" type="uint"/>
		<entry name="Time" type="uint"/>
		<entry name="SSOver" type="uint"/>
		<entry name="AppID" type="int"/>
		<entry name="AppClientVer" type="int"/>
		<entry name="ClientIP" type="uint"/>
		<entry name="SessionKey" type="tinyuint" count="TQQ_KEY_LEN"/>
		<entry name="UnifiedSig2Len" type="short"/>
		<entry name="UnifiedSig2" type="tinyuint" count="TQQ_UNIFIED_MAX_ENCSIGN2_LEN" refer="UnifiedSig2Len"/>
		<entry name="CustomInfoLen" type="short"/>
		<entry name="CustomInfoData" type="tinyuint" count="TQQ_UNIFIED_CUSTOMINFO_LEN" refer="CustomInfoLen"/>
	</struct>

	<struct name="TQQUnifiedAuthInfo" version="10" desc="0xDE signature protocol">
		<entry name="Uin" type="uint"/>
		<entry name="Len" type="tinyuint"/>
		<entry name="SigInfo" type="tinyuint" count="TQQ_UNIFIED_MAX_SIGN_LEN" refer="Len"/>
	</struct>

	<struct name="TPDUExtChgSkey" version="10" desc="Key exchange">
		<entry name="Type" type="short" desc="Default fill zero"/>
		<entry name="Len" type="short" desc="Key length (ciphertext)"/>
		<entry name="EncryptSkey" type="tinyint" count="TPDU_MAX_ENCRYPTSKEY_LEN" refer="Len"/>
	</struct>

	<struct name="TPDUExtQueInfo" version="10" desc="Queue information">
		<entry name="Pos" type="int" desc="Position in queue"/>
		<entry name="Max" type="int" desc="Queue length"/>
		<entry name="WaitTime" type="int" version="13" desc="Estimated queue wait time in seconds"/>
	</struct>

	<union name="TPDUExtAuthData" version="10" desc="Signature data">
		<entry name="AuthQQV1" type="TQQAuthInfo" id="TCONN_SEC_AUTH_QQV1" desc="0x82 protocol"/>
		<entry name="AuthQQV2" type="TQQAuthInfo" id="TCONN_SEC_AUTH_QQV2" desc="0x82 protocol"/>
		<entry name="AuthQQUnified" type="TQQUnifiedAuthInfo" id="TCONN_SEC_AUTH_QQUNIFIED" desc="0xDE protocol"/>
	</union>

	<struct name="TPDUExtAuthInfo" version="10" desc="Signature request packet">
		<entry name="EncMethod" type="int" version="11" desc="Communication encryption type" bindmacrosgroup="TCONN_SEC_ENC"/>
		<entry name="ServiceID" type="int" version="12" desc="Game ID" default="0"/>
		<entry name="AuthType" type="int" desc="Signature type" bindmacrosgroup="TCONN_SEC_AUTH"/>
		<entry name="AuthData" type="TPDUExtAuthData" desc="Signature data" select="AuthType"/>
	</struct>

	<struct name="TPDUIdentInfo" version="10" desc="Connection established packet">
		<entry name="Pos" type="int" desc="Connection index and verification string can be saved for reconnection"/>
		<entry name="Ident" type="char" count="TQQ_IDENT_LEN" desc="Connection verification string"/>
	</struct>

	<struct name="TPDUExtIdent" version="10">
		<entry name="Len" type="int" desc="Connection established packet info length (ciphertext)"/>
		<entry name="EncryptIdent" type="tinyint" count="TPDU_MAX_ENCRYPTIDENT_LEN" refer="Len"/>
	</struct>

	<struct name="TPDUExtRelay" version="10" desc="Reconnection request packet">
		<entry name="EncMethod" type="int" version="11" desc="Communication encryption type" bindmacrosgroup="TCONN_SEC_ENC"/>
		<entry name="RelayType" type="int" desc="Reconnection type" bindmacrosgroup="TPDU_RELAY_TYPE"/>
		<entry name="OldPos" type="int" desc="Placeholder connection index"/>
		<entry name="Len" type="int" desc="Reconnection verification info length (ciphertext)"/>
		<entry name="EncryptIdent" type="tinyint" count="TPDU_MAX_ENCRYPTIDENT_LEN" refer="Len"/>
	</struct>

	<struct name="TPDUExtStop" version="10" desc="Reserved, not currently used">
		<entry name="StopReason" type="int"/>
	</struct>

	<struct name="TPDUSynInfo" version="10" desc="Connection handshake information">
		<entry name="randstr" type="char" count="TQQ_IDENT_LEN"/>
	</struct>

	<struct name="TPDUExtSyn" version="10">
		<entry name="Len" type="tinyuint" desc="Connection handshake info length (ciphertext)"/>
		<entry name="EncryptSynInfo" type="tinyint" count="TPDU_MAX_ENCRYPTSYN_LEN" refer="Len"/>
	</struct>

	<struct name="TPDUExtSynAck" version="10" desc="Three-way handshake request information">
		<entry name="Len" type="tinyuint" desc="Handshake request info length (ciphertext), same structure as connection handshake"/>
		<entry name="EncryptSynInfo" type="tinyuint" count="TPDU_MAX_ENCRYPTSYNACK_LEN" refer="Len"/>
	</struct>

	<struct name="TPDUExtMiBao" version="14" desc="Security question passthrough buffer, ciphertext">
		<entry name="Len" type="ushort" desc="Buffer length"/>
		<entry name="MiBaoBuffer" type="tinyuint" count="TPDU_MAX_MIBAOBUFFER_LEN" refer="Len"/>
	</struct>

	<struct name="TPDUExtClientAddr" version="14" desc="Client real address information">
		<entry name="Uin" type="uint" desc="User ID"/>
		<entry name="IP" type="uint" desc="IP address"/>
		<entry name="Port" type="ushort" desc="Port"/>
		<entry name="ExtInfo" type="char" count="128" desc="Additional information"/>
	</struct>

	<union name="TPDUExt" version="10" desc="Packet header extension information">
		<entry name="ChgSkey" type="TPDUExtChgSkey" id="TPDU_CMD_CHGSKEY"/>
		<entry name="QueInfo" type="TPDUExtQueInfo" id="TPDU_CMD_QUEINFO"/>
		<entry name="AuthInfo" type="TPDUExtAuthInfo" id="TPDU_CMD_AUTH"/>
		<entry name="Ident" type="TPDUExtIdent" id="TPDU_CMD_IDENT"/>
		<entry name="Relay" type="TPDUExtRelay" id="TPDU_CMD_RELAY"/>
		<entry name="Stop" type="TPDUExtStop" id="TPDU_CMD_STOP"/>
		<entry name="Syn" type="TPDUExtSyn" id="TPDU_CMD_SYN"/>
		<entry name="SynAck" type="TPDUExtSynAck" id="TPDU_CMD_SYNACK"/>
		<entry name="MbaQueryRsp" type="TPDUExtMiBao" version="14" id="TPDU_CMD_MBA_QUERYRSP"/>
		<entry name="MbaVerifyReq" type="TPDUExtMiBao" version="14" id="TPDU_CMD_MBA_VERIFYREQ"/>
		<entry name="MbaVerifyRsp" type="TPDUExtMiBao" version="14" id="TPDU_CMD_MBA_VERIFYRSP"/>
		<entry name="ClientAddr" type="TPDUExtClientAddr" version="14" id="TPDU_CMD_CLIENT_ADDR"/>
	</union>

	<struct name="TPDUBase_Old" version="10" desc="Base packet header before version 14">
		<entry name="Magic" type="tinyuint" desc="Magic number"/>
		<entry name="Version" type="tinyuint" desc="Protocol version, refer to TPDU_VERSION"/>
		<entry name="Cmd" type="tinyuint" desc="Packet type"/>
		<entry name="HeadLen" type="tinyuint" desc="Header length"/>
		<entry name="EncHeadLen" type="tinyuint" version="11" desc="Valid for upstream packets, header additional info length, encrypted with body"/>
		<entry name="BodyLen" type="int" desc="Body length"/>
	</struct>

	<struct name="TPDUBase" version="10" desc="Base packet header information">
		<entry name="Magic" type="tinyuint" desc="Magic number"/>
		<entry name="Version" type="tinyuint" desc="Protocol version, refer to TPDU_VERSION"/>
		<entry name="Cmd" type="tinyuint" desc="Packet type"/>
		<entry name="EncHeadLen" type="tinyuint" version="11" desc="Valid for upstream packets, header additional info length, encrypted with body"/>
		<entry name="HeadLen" type="int" desc="Header length"/>
		<entry name="BodyLen" type="int" desc="Body length"/>
	</struct>

	<struct name="TPDUHead_Old" version="10" desc="Packet header before version 14" versionindicator="Base.Version" sizeinfo="Base.HeadLen">
		<entry name="Base" type="TPDUBase_Old" desc="Base information"/>
		<entry name="Ext" type="TPDUExt" desc="Extension information" select="Base.Cmd"/>
	</struct>

	<struct name="TPDUHead" version="10" desc="Packet header" versionindicator="Base.Version" sizeinfo="Base.HeadLen">
		<entry name="Base" type="TPDUBase" desc="Base information"/>
		<entry name="Ext" type="TPDUExt" desc="Extension information" select="Base.Cmd"/>
	</struct>

	<struct name="TPDUEncHead" version="11" desc="Additional header info, do not define strings or data types where network order differs from local order">
		<entry name="sequence" type="uint"/>
	</struct>

	<struct name="TPDUFrame" version="10" desc="CS communication packet = Plaintext: Header (base info + extension info) + Ciphertext: Body (additional header info + application packet)">
		<entry name="Head" type="TPDUHead"/>
		<entry name="Body" type="tinyint" refer="Base.BodyLen"/>
	</struct>

</metalib>